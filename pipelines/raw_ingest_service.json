{
  "description": "raw_ingest_service: web access/req/error baseline. message → event.original, keep agent/host/log meta as-is, set @timestamp",
  "processors": [
    { "rename": { "field": "message", "target_field": "event.original", "ignore_missing": true } },
    { "set":    { "field": "@timestamp", "value": "{{{_ingest.timestamp}}}", "override": false } }
  ],
  "on_failure": [
    { "set": { "field": "error.message", "value": "{{{_ingest.on_failure_message}}}" } }
  ]
}
