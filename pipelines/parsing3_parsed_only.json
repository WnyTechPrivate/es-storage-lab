{
  "description": "parsing3_parsed_only: same parsing as parsing2_full, then drop event.original",
  "processors": [
    { "pipeline": { "name": "parsing2_full" } },
    { "remove":   { "field": "event.original", "ignore_missing": true } }
  ],
  "on_failure": [
    { "set": { "field": "error.message", "value": "{{{_ingest.on_failure_message}}}" } }
  ]
}
